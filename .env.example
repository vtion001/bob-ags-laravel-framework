APP_NAME=BOB
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

LOG_CHANNEL=stack

DB_CONNECTION=sqlite
DB_DATABASE=/path/to/bob-ags-laravel/database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8001,127.0.0.1,127.0.0.1:8001

CACHE_DRIVER=file
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# CallTrackingMetrics API Credentials
CTM_ACCESS_KEY=your_ctm_access_key
CTM_SECRET_KEY=your_ctm_secret_key
CTM_ACCOUNT_ID=your_ctm_account_id
CTM_BASIC_AUTH=base64_encoded_ctm_auth

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OpenRouter API Key for AI Analysis
OPENROUTER_API_KEY=your_openrouter_api_key

# AssemblyAI API Key for Audio Transcription
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# FastAPI Service (runs on port 9000)
FASTAPI_URL=http://localhost:9000
